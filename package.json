    "ioredis":            "^5.4.1",
    "dotenv":             "^16.4.5",
    "axios":              "^1.7.7",
    "winston":            "^3.15.0",
    "zod":                "^3.23.8",
    "uuid":               "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors":    "^2.8.17",
    "@types/node":    "^22.7.4",
    "@types/uuid":    "^10.0.0",
    "tsx":            "^4.19.1",
    "typescript":     "^5.6.2"
