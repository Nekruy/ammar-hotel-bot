# AMMAR Hotel Bot — переменные окружения
# ═══════════════════════════════════════════

# CLAUDE AI (главный мозг)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-6

# TELEGRAM — бот для гостей (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxx

# TELEGRAM — бот для персонала (второй бот)
STAFF_BOT_TOKEN=7987654321:AAHxxxxxxxxxxxxxxxxxxxxxxxx
STAFF_CHAT_KITCHEN=-1001234567890
STAFF_CHAT_HOUSEKEEPING=-1009876543210
STAFF_CHAT_RECEPTION=-1001122334455
STAFF_CHAT_GM=-1005544332211

# WHATSAPP
ENABLE_WHATSAPP=true

# БАЗА ДАННЫХ
DATABASE_URL=postgresql://ammar:password@localhost:5432/ammar_bot
REDIS_URL=redis://localhost:6379

# CHECKINN (будет подключено позже)
CHECKINN_ENABLED=false
# CHECKINN_API_URL=https://api.checkinn.tj/v1
# CHECKINN_API_KEY=your-key

# СЕРВЕР
PORT=3000
NODE_ENV=production
WEBHOOK_SECRET=change-this-secret
DOMAIN=bot.ammar-hotel.tj
